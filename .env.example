# Database
DB_PATH=data/crawler.db

# Authentication (required for seed-users command)
BFI_ADMIN_PASSWORD=
BFI_ANALYST_PASSWORD=
BFI_COOKIE_SECRET=generate-a-random-64-char-hex-string

# Cache revalidation (crawler -> Next.js)
BFI_APP_URL=https://bankfeeindex.com
BFI_REVALIDATE_TOKEN=generate-a-random-token

# Litestream SQLite backup (optional, S3-compatible)
LITESTREAM_REPLICA_BUCKET=
LITESTREAM_REPLICA_ENDPOINT=
LITESTREAM_REPLICA_REGION=us-east-1
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=bankfeeindex.com

# Error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Node
NODE_ENV=production

# ── System Dependencies (for Python crawler) ──
# apt install tesseract-ocr poppler-utils
# tesseract-ocr: OCR fallback for scanned PDF fee schedules
# poppler-utils: pdftotext for PDF text extraction (pdfplumber dependency)
