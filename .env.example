# Database
DB_PATH=data/crawler.db

# Authentication (required for seed-users command)
# Note: BFI_ prefix kept for deployment stability
BFI_ADMIN_PASSWORD=
BFI_ANALYST_PASSWORD=
BFI_COOKIE_SECRET=generate-a-random-64-char-hex-string

# Cache revalidation (crawler -> Next.js)
BFI_APP_URL=https://feeinsight.com
BFI_REVALIDATE_TOKEN=generate-a-random-token

# Site URL (used for metadata, sitemaps, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://feeinsight.com

# Litestream SQLite backup (optional, S3-compatible)
LITESTREAM_REPLICA_BUCKET=
LITESTREAM_REPLICA_ENDPOINT=
LITESTREAM_REPLICA_REGION=us-east-1
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=

# AI Research Agents (required for /admin/research chat)
ANTHROPIC_API_KEY=

# FRED Economic Data (required for ingest-fred command)
FRED_API_KEY=

# BLS Public Data API (optional, improves rate limits for ingest-bls)
# Register free at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# Census ACS API (optional, improves rate limits for ingest-census-acs)
# Register free at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Stripe Payments (required for Pro subscriptions)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# Analytics (optional)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=feeinsight.com

# Error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# Node
NODE_ENV=production

# ── System Dependencies (for Python crawler) ──
# apt install tesseract-ocr poppler-utils
# tesseract-ocr: OCR fallback for scanned PDF fee schedules
# poppler-utils: pdftotext for PDF text extraction (pdfplumber dependency)
