# Database
DB_PATH=data/crawler.db

# Authentication (required for seed-users command)
BFI_ADMIN_PASSWORD=
BFI_ANALYST_PASSWORD=
BFI_COOKIE_SECRET=generate-a-random-64-char-hex-string

# Cache revalidation (crawler → Next.js)
BFI_APP_URL=https://bankfeeindex.com
BFI_REVALIDATE_TOKEN=generate-a-random-token

# Node
NODE_ENV=production
